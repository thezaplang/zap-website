{
  "name": "zap",
  "scopeName": "source.zap",
  "fileTypes": ["zp"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#attributes" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zap",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.zap",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.zap", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.zap",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.zap", "match": "\\\\." }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zap",
          "match": "\\b(if|else|while|for|in|break|continue|return|fail)\\b"
        },
        {
          "name": "keyword.declaration.zap",
          "match": "\\b(fun|var|const|global|class|struct|record|enum|alias|import|pub|priv|prot|static|unsafe|ext|new|weak|ref|or|where|iftype)\\b"
        },
        {
          "name": "constant.language.zap",
          "match": "\\b(true|false|null|self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.zap",
          "match": "\\b(Int|Int8|Int16|Int32|Int64|UInt|UInt8|UInt16|UInt32|UInt64|Float|Float32|Float64|Bool|Char|String|Void)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.zap",
          "match": "@\\w+"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.zap",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.zap",
          "match": "(\\+|-|\\*|/|%|==|!=|<=|>=|<|>|&&|\\|\\||!|~|\\?:|\\?|&|\\|)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.zap",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "name": "entity.name.type.zap",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
